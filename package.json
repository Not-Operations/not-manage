{
  "name": "clio-manage",
  "version": "0.1.15",
  "description": "Unofficial command-line tool for Clio Manage integrations",
  "license": "Apache-2.0",
  "private": false,
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Not-Operations/clio-manage"
  },
  "bin": {
    "clio-manage": "bin/clio-manage.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "NOTICE"
  ],
  "keywords": [
    "clio",
    "clio-manage",
    "command-line",
    "terminal",
    "legal",
    "law-firm",
    "case-management",
    "oauth2",
    "mcp",
    "cli"
  ],
  "scripts": {
    "check": "npm run check:syntax && npm test",
    "check:security": "npm audit --audit-level=high",
    "check:syntax": "node --check bin/clio-manage.js && node --check src/*.js && node --check test/*.test.js && node --check test/helpers/*.js",
    "dev": "node bin/clio-manage.js",
    "pack:check": "npm pack --dry-run",
    "postinstall": "node src/postinstall.js",
    "start": "node bin/clio-manage.js",
    "test": "node --test test/*.test.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "keytar": "^7.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
